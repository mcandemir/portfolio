---
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import CircuitBackground from "@/components/CircuitBackground.astro";
import Sidebar from "@/components/Sidebar.astro";
import PersistentTerminal from "@/components/PersistentTerminal";
import { ViewTransitions } from "astro:transitions";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  wide?: boolean;
  /** Show left sidebar (name, links, blog). When false, sidebar hidden on mobile. */
  sidebar?: boolean;
  /** When true, sidebar stays visible on mobile. Only home uses this. */
  sidebarOnMobile?: boolean;
}

const {
  title,
  description = "Software Engineer — Backend Systems, Cloud, and Infrastructure.",
  ogImage = "/og-default.png",
  wide = false,
  sidebar = false,
  sidebarOnMobile = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const showSidebar = sidebar;
const mainWide = wide || showSidebar;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Portfolio</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Portfolio`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Portfolio`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Preconnect to font origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col">
    <CircuitBackground />
    <Nav />
    <main class:list={["flex-1 mx-auto px-4 sm:px-6 py-8 sm:py-12 w-full animate-fade-in", mainWide ? "max-w-6xl" : "max-w-4xl"]}>
      {showSidebar ? (
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,280px)_1fr] gap-8 lg:gap-12">
          <aside class:list={[!sidebarOnMobile && "hidden lg:block"]}>
            <Sidebar />
          </aside>
          <div class="min-w-0">
            <slot />
          </div>
        </div>
      ) : (
        <slot />
      )}
    </main>
    <Footer />
    <PersistentTerminal client:idle transition:persist="terminal" />
  </body>
</html>
