---
const year = new Date().getFullYear();
---
<footer class="border-t border-terminal-border mt-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-6 sm:py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="font-mono text-xs text-terminal-muted">
      <span class="text-terminal-green">&gt;</span> &copy; {year} — Built with Astro
    </p>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/mcandemir"
        target="_blank"
        rel="noopener"
        class="font-mono text-xs text-terminal-muted hover:text-terminal-green transition-colors"
        aria-label="GitHub"
      >
        github
      </a>
      <a
        href="https://www.linkedin.com/in/mcandemir9/"
        target="_blank"
        rel="noopener"
        class="font-mono text-xs text-terminal-muted hover:text-terminal-green transition-colors"
        aria-label="LinkedIn"
      >
        linkedin
      </a>
      <a
        href="/rss.xml"
        class="font-mono text-xs text-terminal-muted hover:text-terminal-green transition-colors"
        aria-label="RSS Feed"
      >
        rss
      </a>
    </div>
  </div>
</footer>
