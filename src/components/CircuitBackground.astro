---
---
<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
  <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#00ff41" stroke-width="0.5" />
      </pattern>
      <pattern id="circuit-dots" width="40" height="40" patternUnits="userSpaceOnUse">
        <circle cx="0" cy="0" r="1" fill="#00ff41" />
        <circle cx="40" cy="0" r="1" fill="#00ff41" />
        <circle cx="0" cy="40" r="1" fill="#00ff41" />
        <circle cx="40" cy="40" r="1" fill="#00ff41" />
      </pattern>
      <radialGradient id="fade" cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="white" stop-opacity="1" />
        <stop offset="100%" stop-color="white" stop-opacity="0" />
      </radialGradient>
      <mask id="fade-mask">
        <rect width="100%" height="100%" fill="url(#fade)" />
      </mask>
    </defs>
    <g mask="url(#fade-mask)">
      <rect width="100%" height="100%" fill="url(#grid)" />
      <rect width="100%" height="100%" fill="url(#circuit-dots)" />
      <!-- Horizontal circuit traces -->
      <line x1="0" y1="120" x2="300" y2="120" stroke="#00ff41" stroke-width="0.5" opacity="0.3" />
      <line x1="400" y1="280" x2="800" y2="280" stroke="#00ff41" stroke-width="0.5" opacity="0.2" />
      <line x1="200" y1="440" x2="600" y2="440" stroke="#00ff41" stroke-width="0.5" opacity="0.15" />
      <!-- Vertical circuit traces -->
      <line x1="320" y1="0" x2="320" y2="240" stroke="#00ff41" stroke-width="0.5" opacity="0.2" />
      <line x1="640" y1="160" x2="640" y2="480" stroke="#00ff41" stroke-width="0.5" opacity="0.15" />
      <!-- Circuit nodes -->
      <circle cx="320" cy="120" r="3" fill="none" stroke="#00ff41" stroke-width="0.5" opacity="0.4" />
      <circle cx="640" cy="280" r="3" fill="none" stroke="#00ff41" stroke-width="0.5" opacity="0.3" />
      <circle cx="300" cy="440" r="2" fill="#00ff41" opacity="0.3" />
    </g>
  </svg>
</div>
