---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { linkedinPosts } from "@/data/linkedin-posts";

const posts = [...linkedinPosts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---
<BaseLayout title="LinkedIn" description="Posts and updates from LinkedIn.">
  <section class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold text-terminal-text">LinkedIn</h1>
      <p class="font-mono text-sm text-terminal-muted mt-2">
        Posts and updates. Follow me{" "}
        <a
          href="https://www.linkedin.com/in/mcandemir9/"
          target="_blank"
          rel="noopener"
          class="text-terminal-green hover:underline"
        >
          @mcandemir9
        </a>
      </p>
      <p class="font-mono text-xs text-terminal-muted/70 mt-1">
        Embeds may not load due to third-party cookie blocking, ad blockers, or strict privacy settings. Use the links below to open posts directly on LinkedIn.
      </p>
    </div>

    <div class="space-y-8">
      {posts.map((post) => {
        const embedUrl = `https://www.linkedin.com/embed/feed/${post.postId}`;
        const viewUrl = `https://www.linkedin.com/feed/${post.postId}`;
        return (
          <article class="border border-terminal-border rounded-lg overflow-hidden bg-terminal-surface">
            <div class="px-4 py-2 border-b border-terminal-border flex items-center justify-between gap-2">
              <div>
                {post.title && (
                  <h2 class="font-mono text-sm text-terminal-muted">{post.title}</h2>
                )}
                <time class="font-mono text-xs text-terminal-muted/70">
                  {post.date}
                </time>
              </div>
              <a
                href={viewUrl}
                target="_blank"
                rel="noopener"
                class="font-mono text-xs px-3 py-1.5 bg-terminal-green/10 text-terminal-green border border-terminal-green/20 rounded hover:bg-terminal-green/20 transition-colors shrink-0"
              >
                View on LinkedIn ↗
              </a>
            </div>
            <div class="p-4 min-h-[400px] flex flex-col items-center justify-center bg-terminal-bg/50 gap-4">
              <iframe
                src={embedUrl}
                height="964"
                width="504"
                frameborder="0"
                allowfullscreen
                title="LinkedIn post"
                class="max-w-full rounded border-0"
              />
              <p class="font-mono text-xs text-terminal-muted text-center max-w-md">
                Embed not loading?{" "}
                <a href={viewUrl} target="_blank" rel="noopener" class="text-terminal-green hover:underline">
                  Open post on LinkedIn
                </a>
                {" "}— embeds may not work on localhost.
              </p>
            </div>
          </article>
        );
      })}
    </div>

    {posts.length === 0 && (
      <div class="py-16 text-center border border-dashed border-terminal-border rounded-lg">
        <p class="text-terminal-muted font-mono text-sm">No embedded posts yet.</p>
        <p class="text-terminal-muted/70 font-mono text-xs mt-2">
          Add posts to src/data/linkedin-posts.ts
        </p>
      </div>
    )}
  </section>
</BaseLayout>
