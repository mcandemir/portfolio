---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const paths = await Promise.all(
    projects.map(async (project) => {
      let readmeHtml: string | null = null;
      if (project.data.useReadme && project.data.githubUrl) {
        const match = project.data.githubUrl.match(/github\.com\/([^/]+)\/([^/]+?)(?:\/|$)/);
        if (match) {
          const [_, owner, repo] = match;
          for (const branch of ["main", "master"]) {
            try {
              const res = await fetch(
                `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/README.md`,
              );
              if (res.ok) {
                const raw = await res.text();
                const base = `https://raw.githubusercontent.com/${owner}/${repo}/${branch}`;
                const withImages = raw.replace(
                  /!\[([^\]]*)\]\(([^)]+)\)/g,
                  (_, alt, src) =>
                    `![${alt}](${src.startsWith("http") ? src : `${base}/${src.replace(/^\//, "")}`})`,
                );
                readmeHtml = await marked(withImages);
                break;
              }
            } catch {
              /* try next branch */
            }
          }
        }
      }
      return {
        params: { id: project.id },
        props: { project, readmeHtml },
      };
    }),
  );
  return paths;
}

const { project, readmeHtml } = Astro.props;
const { Content } = await render(project);
---
<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="space-y-8">
    <!-- Breadcrumb -->
    <nav class="font-mono text-xs text-terminal-muted">
      <a href="/projects" class="hover:text-terminal-green transition-colors">~/projects</a>
      <span class="mx-1">/</span>
      <span class="text-terminal-text">{project.data.title.toLowerCase().replace(/\s+/g, "-")}</span>
    </nav>

    <!-- Header -->
    <header class="space-y-4">
      <h1 class="text-3xl font-bold text-terminal-text">{project.data.title}</h1>
      <p class="text-lg text-terminal-muted leading-relaxed">{project.data.description}</p>

      <div class="flex flex-wrap items-center gap-3 pt-2">
        {project.data.githubUrl && (
          <a
            href={project.data.githubUrl}
            target="_blank"
            rel="noopener"
            class="font-mono text-xs px-3 py-1.5 bg-terminal-surface border border-terminal-border rounded hover:border-terminal-green/30 text-terminal-muted hover:text-terminal-green transition-all"
          >
            github ↗
          </a>
        )}
        {project.data.liveUrl && (
          <a
            href={project.data.liveUrl}
            target="_blank"
            rel="noopener"
            class="font-mono text-xs px-3 py-1.5 bg-terminal-green/10 border border-terminal-green/20 rounded text-terminal-green hover:bg-terminal-green/20 transition-all"
          >
            live ↗
          </a>
        )}
      </div>

      <!-- Meta -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4 border-t border-terminal-border">
        <div>
          <p class="font-mono text-xs text-terminal-muted uppercase tracking-wider">Role</p>
          <p class="text-sm text-terminal-text mt-1">{project.data.role}</p>
        </div>
        <div>
          <p class="font-mono text-xs text-terminal-muted uppercase tracking-wider">Impact</p>
          <p class="text-sm text-terminal-green mt-1">{project.data.impact}</p>
        </div>
        <div>
          <p class="font-mono text-xs text-terminal-muted uppercase tracking-wider">Date</p>
          <p class="text-sm text-terminal-text mt-1">{project.data.date.toISOString().slice(0, 10)}</p>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="flex flex-wrap gap-2">
        {project.data.techStack.map((tech) => (
          <span class="font-mono text-xs px-2 py-0.5 bg-terminal-surface border border-terminal-border rounded text-terminal-muted">
            {tech}
          </span>
        ))}
      </div>
    </header>

    <!-- Cover Image (only when not using README) -->
    {project.data.coverImage && !readmeHtml && (
      <figure class="rounded-lg overflow-hidden border border-terminal-border">
        <img
          src={project.data.coverImage}
          alt={project.data.title}
          class="w-full h-auto object-cover"
        />
      </figure>
    )}

    <!-- Content -->
    <div class="prose-terminal">
      {readmeHtml ? (
        <div set:html={readmeHtml} />
      ) : (
        <Content />
      )}
    </div>
  </article>
</BaseLayout>
