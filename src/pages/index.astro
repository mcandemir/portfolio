---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { labProjects } from "@/data/lab-projects";
import { events as eventsData } from "@/data/events";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const experiences = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order,
);
const latestExperience = experiences[0];

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

const recentAchievements = (await getCollection("achievements"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const recentEvents = [...eventsData]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---
<BaseLayout title="Home">
  <!-- Experience -->
  {latestExperience && (
    <section class="pb-12 pt-2 animate-fade-in">
      <h2 class="font-mono text-xs text-terminal-muted mb-4 uppercase tracking-widest">
        Experience
      </h2>
      <a
        href="/experience"
        class="group block p-5 border border-terminal-border rounded-lg hover:border-terminal-green/30 hover:bg-terminal-surface/50 transition-all"
      >
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <h3 class="text-xl font-semibold text-terminal-text group-hover:text-terminal-green transition-colors">
            {latestExperience.data.position}
          </h3>
          <span class="font-mono text-sm text-terminal-green">@ {latestExperience.data.company}</span>
        </div>
        <p class="font-mono text-xs text-terminal-muted mt-2">
          {formatDate(latestExperience.data.startDate)} — {latestExperience.data.current ? "Present" : (latestExperience.data.endDate ? formatDate(latestExperience.data.endDate) : "—")}
          <span class="text-terminal-muted/60 mx-1">·</span>
          {latestExperience.data.location}
        </p>
        <ul class="mt-3 space-y-1">
          {latestExperience.data.achievements.slice(0, 3).map((a) => (
            <li class="flex items-start gap-2 text-sm text-terminal-text/80">
              <span class="text-terminal-green mt-0.5 shrink-0">▸</span>
              <span>{a}</span>
            </li>
          ))}
        </ul>
        {latestExperience.data.techStack.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {latestExperience.data.techStack.slice(0, 5).map((tech) => (
              <span class="font-mono text-xs px-2 py-0.5 bg-terminal-surface border border-terminal-border rounded text-terminal-muted">
                {tech}
              </span>
            ))}
          </div>
        )}
        <span class="font-mono text-xs text-terminal-green opacity-0 group-hover:opacity-100 transition-opacity mt-3 inline-block">
          →
        </span>
      </a>
      <a href="/experience" class="font-mono text-xs text-terminal-green hover:underline mt-4 inline-block">
        view all {experiences.length} roles →
      </a>
    </section>
  )}

  <!-- Featured Projects -->
  <section class="py-12">
    <h2 class="font-mono text-xs text-terminal-muted mb-6 uppercase tracking-widest">
      Featured Projects
    </h2>
    <div class="grid gap-4">
      {featuredProjects.map((project) => (
        <a
          href={`/projects/${project.id}`}
          class="group block p-5 border border-terminal-border rounded-lg hover:border-terminal-green/30 hover:bg-terminal-surface/50 transition-all"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-1.5">
              <h3 class="font-semibold text-terminal-text group-hover:text-terminal-green transition-colors">
                {project.data.title}
              </h3>
              <p class="text-sm text-terminal-muted leading-relaxed">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2 pt-1">
                {project.data.techStack.slice(0, 4).map((tech) => (
                  <span class="font-mono text-xs px-2 py-0.5 bg-terminal-surface border border-terminal-border rounded text-terminal-muted">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
            <span class="font-mono text-xs text-terminal-green opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
              →
            </span>
          </div>
        </a>
      ))}
    </div>
    <a
      href="/projects"
      class="font-mono text-xs text-terminal-green hover:underline mt-4 inline-block"
    >
      view all {allProjects.length} projects →
    </a>
  </section>

  <!-- The Lab (preview) -->
  <section class="py-12">
    <h2 class="font-mono text-xs text-terminal-muted mb-6 uppercase tracking-widest">
      The Lab
    </h2>
    <p class="text-sm text-terminal-muted mb-4">
      Early experiments, CLI tools, and projects that shaped the path.
    </p>
    <div class="flex flex-wrap gap-2 mb-4">
      {labProjects.slice(0, 8).map((p) => (
        <a
          href={p.githubUrl}
          target="_blank"
          rel="noopener"
          class="font-mono text-xs px-2 py-1 bg-terminal-surface border border-terminal-border rounded hover:border-terminal-green/30 text-terminal-muted hover:text-terminal-green transition-colors"
        >
          {p.title}
        </a>
      ))}
    </div>
    <a
      href="/lab"
      class="font-mono text-xs text-terminal-green hover:underline"
    >
      view all {labProjects.length} lab projects →
    </a>
  </section>

  <!-- Achievements -->
  <section class="py-12">
    <h2 class="font-mono text-xs text-terminal-muted mb-6 uppercase tracking-widest">
      Achievements
    </h2>
    <div class="space-y-3">
      {recentAchievements.map((post) => (
        <a
          href={`/achievements/${post.id}`}
          class="group flex items-baseline justify-between gap-4 py-2 border-b border-terminal-border/50 hover:border-terminal-green/30 transition-colors"
        >
          <span class="text-terminal-text group-hover:text-terminal-green transition-colors">
            {post.data.title}
          </span>
          <span class="font-mono text-xs text-terminal-muted shrink-0">
            {post.data.date.toISOString().slice(0, 10)}
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Events -->
  <section class="py-12">
    <h2 class="font-mono text-xs text-terminal-muted mb-6 uppercase tracking-widest">
      Events
    </h2>
    <p class="text-sm text-terminal-muted mb-4">
      Talks, meetups, and conferences I've attended.
    </p>
    {recentEvents.length > 0 ? (
      <div class="space-y-4">
        {recentEvents.map((event) => (
          <a
            href="/events"
            class="block p-4 border border-terminal-border rounded-lg hover:border-terminal-green/30 transition-colors"
          >
            <div class="font-mono text-xs text-terminal-muted">
              {event.title} · {event.date}
            </div>
          </a>
        ))}
        <a href="/events" class="font-mono text-xs text-terminal-green hover:underline">
          view all events →
        </a>
      </div>
    ) : (
      <a
        href="/events"
        class="font-mono text-sm px-4 py-2 text-terminal-muted border border-terminal-border rounded hover:text-terminal-text hover:border-terminal-muted transition-colors inline-block"
      >
        view events →
      </a>
    )}
  </section>
</BaseLayout>
