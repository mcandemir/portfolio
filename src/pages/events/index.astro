---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { events as eventsData } from "@/data/events";

const events = [...eventsData].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---
<BaseLayout title="Events" description="Talks, meetups, and conferences." sidebar>
  <section class="space-y-8">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-terminal-text">Events</h1>
      <p class="font-mono text-sm text-terminal-muted mt-2">
        Talks, meetups, and conferences I've attended.
      </p>
    </div>

    <div class="space-y-8">
      {events.map((event) => (
        <article class="border border-terminal-border rounded-lg overflow-hidden bg-terminal-surface">
          <div class="flex flex-col sm:flex-row gap-0 sm:gap-6">
            <div class="sm:w-64 shrink-0">
              <img
                src={event.image}
                alt={event.title}
                class="w-full h-48 sm:h-full sm:min-h-[200px] object-cover"
              />
            </div>
            <div class="p-4 sm:p-5 flex-1 flex flex-col">
              <h2 class="font-semibold text-terminal-text">{event.title}</h2>
              <time class="font-mono text-xs text-terminal-muted mt-1">
                {event.date}
              </time>
              <p class="text-sm text-terminal-text/80 mt-3 leading-relaxed">
                {event.text}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>

    {events.length === 0 && (
      <div class="py-16 text-center border border-dashed border-terminal-border rounded-lg">
        <p class="text-terminal-muted font-mono text-sm">No events yet.</p>
        <p class="text-terminal-muted/70 font-mono text-xs mt-2">
          Add events to src/data/events.ts
        </p>
      </div>
    )}
  </section>
</BaseLayout>
