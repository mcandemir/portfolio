---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("achievements"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Achievements" description="Talks, articles, and milestones." sidebar>
  <section class="space-y-8">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-terminal-text">Achievements</h1>
      <p class="font-mono text-sm text-terminal-muted mt-2">ls ~/achievements</p>
    </div>

    <div class="space-y-6">
      {posts.map((post) => (
        <a
          href={`/achievements/${post.id}`}
          class="group block p-5 border border-terminal-border rounded-lg hover:border-terminal-green/30 hover:bg-terminal-surface/50 transition-all"
        >
          <div class="space-y-2">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h2 class="text-lg font-semibold text-terminal-text group-hover:text-terminal-green transition-colors">
                {post.data.title}
              </h2>
              <span class="font-mono text-xs text-terminal-muted shrink-0">
                {post.data.date.toISOString().slice(0, 10)}
              </span>
            </div>
            <p class="text-sm text-terminal-muted leading-relaxed">
              {post.data.description}
            </p>
            <div class="flex flex-wrap items-center gap-2 pt-1">
              {post.data.tags.map((tag) => (
                <span class="font-mono text-xs text-terminal-green/60">#{tag}</span>
              ))}
              {post.data.readingTime && (
                <span class="font-mono text-xs text-terminal-muted">
                  · {post.data.readingTime} min read
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
